# ── Required ─────────────────────────────────────────────────────────
# Your OpenAI-compatible model endpoint.
OPENAI_BASE_URL=
OPENAI_API_KEY=
DABSTEP_MODEL=

# Your MemoryLake knowledge plane.
MEMORYLAKE_API_KEY=

# ── Optional (sensible defaults) ─────────────────────────────────────
# Separate teacher/labeling model; falls back to the solver endpoint.
#DABSTEP_TEACHER_MODEL=
#DABSTEP_TEACHER_BASE_URL=
#DABSTEP_TEACHER_API_KEY=

#MEMORYLAKE_PROJECT_ID=        # auto-created by `dabstep-agent freeze` if unset
#MEMORYLAKE_USER_ID=            # default dabstep-agent
#MEMORYLAKE_BASE_URL=           # default https://app.memorylake.ai
#DABSTEP_THINKING=              # default high
#DABSTEP_GENERATED_SKILLS=      # primary (default) | off
#DABSTEP_GENERATED_SKILLS_DIR=  # default artifacts/skills
#DABSTEP_MEMORY_ROUTER_MODE=    # off (default) | hosted | byok
